# CurrencyDesk server — local secrets. Copy to `server/.env` and fill in.
# `.env` is gitignored (never committed). In production these are set in the
# Render dashboard instead. The server loads this file automatically on boot.

# --- Transactional email (signup verification codes) via Resend ------------
# Get a key at https://resend.com (free tier). Until BOTH are set, codes are
# logged to the server console instead of emailed.
#   Quick test (no domain needed): send only to the email you signed up to
#   Resend with, using their onboarding sender:
#     EMAIL_FROM="CurrencyDesk <onboarding@resend.dev>"
#   Production (send to anyone): verify your own domain in Resend, then:
#     EMAIL_FROM="CurrencyDesk <noreply@yourdomain.com>"
RESEND_API_KEY=
EMAIL_FROM=

# --- Platform admin (who can see the cross-tenant Admin Console) ------------
# Comma-separated emails. These accounts get the "every desk that signed up"
# view; a normal tenant owner does not.
PLATFORM_ADMIN_EMAILS=
# First-run operator login as "email:password" — creates/updates a platform
# admin account so you can reach /admin on a fresh deploy. REMOVE after signing
# in (while set, every boot resets the password). e.g. admin@yourco.com:changeme
PLATFORM_ADMIN_BOOTSTRAP=

# --- Other optional local secrets (leave blank to use defaults) ------------
# OXR_APP_ID=          # Open Exchange Rates app id (live market rates)
# SEED_PASSWORD=       # first-boot staff password for a fresh local DB
# DATABASE_URL=        # set to use managed Postgres locally; unset = embedded PGlite
